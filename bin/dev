# format.json {
      #   render json: {
      #     is_demo: params[:is_demo],
      #     stories: JSON.parse(params[:stories]),
      #   }
      # }

      format.json do
        # Allow cross-origin fetch from client websites embedding the plugin.
        response.set_header('Access-Control-Allow-Origin', '*')
        render json: { html: plugin_view(@company) }
      end


# DEPRECATION WARNING: `render :text` is deprecated because it does not actually render a `text/plain` response.
        # Switch to `render plain: 'plain text'` to render as `text/plain`, `render html: '<strong>HTML</strong>'` to render as `text/html`,
        # or `render body: 'raw'` to match the deprecated behavior and render with the default Content-Type, which is `text/plain`.
        # render(text: jsonp)

#!/usr/bin/env sh

if gem list --no-installed --exact --silent foreman; then
  echo "Installing foreman..."
  gem install foreman
fi

# Default to port 3000 if not specified
export PORT="${PORT:-3000}"

# Optionally enable custom stylesheet builds in development.
# Usage:
#   bin/dev --custom              # compile/watch all custom stylesheets
#   bin/dev --custom=<subdomain>  # compile/watch one subdomain directory
# NOTE: bin/dev accepts only the options above. Unknown arguments fail fast.
CUSTOM_SUBDOMAIN=""
ENABLE_CUSTOM_CSS=0

case "$1" in
  --custom)
    ENABLE_CUSTOM_CSS=1
    shift
    ;;
  --custom=*)
    ENABLE_CUSTOM_CSS=1
    CUSTOM_SUBDOMAIN="${1#*=}"
    if [ -z "$CUSTOM_SUBDOMAIN" ]; then
      echo "Missing value for --custom=<subdomain>" >&2
      exit 1
    fi
    shift
    ;;
esac

if [ "$#" -gt 0 ]; then
  echo "Unknown option(s): $*" >&2
  echo "Usage:" >&2
  echo "  bin/dev" >&2
  echo "  bin/dev --custom" >&2
  echo "  bin/dev --custom=<subdomain>" >&2
  exit 1
fi

if [ "$ENABLE_CUSTOM_CSS" -eq 1 ] && [ -n "$CUSTOM_SUBDOMAIN" ]; then
  CUSTOM_DIR="app/assets/stylesheets/custom/$CUSTOM_SUBDOMAIN"
  if [ ! -d "$CUSTOM_DIR" ]; then
    echo "Invalid subdomain selector: $CUSTOM_SUBDOMAIN" >&2
    echo "Expected directory not found: $CUSTOM_DIR" >&2
    exit 1
  fi
fi

if [ "$ENABLE_CUSTOM_CSS" -eq 1 ]; then
  export ENABLE_CUSTOM_CSS=1
  if [ -n "$CUSTOM_SUBDOMAIN" ]; then
    export CUSTOM_SUBDOMAIN
    echo "Compiling custom styles for subdomain: $CUSTOM_SUBDOMAIN"
  else
    echo "Compiling custom styles for all subdomains"
  fi
fi

exec foreman start -f Procfile.dev --env /dev/null "$@"
